# ==============================================================================
# ШАБЛОН .env ДЛЯ СЕРВЕРА 185.129.51.40 (тестовый/staging деплой, DEBUG=True)
# ==============================================================================
# На сервере:
#   cp .env.prod.example .env
#   nano .env        # поменяй пароли в местах CHANGE_ME
#
# Этот режим печатает OTP-код в логи (docker compose logs -f backend),
# SMS реально НЕ отправляются. Для настоящего прода см. конец файла DEPLOY.md.
# ==============================================================================

# ------------------------------------------------------------------------------
# Django
# ------------------------------------------------------------------------------
# Используем dev-настройки: DEBUG=True, ALLOWED_HOSTS=['*'], OTP в консоль,
# обязательные секреты (SMS) НЕ требуются.
DJANGO_SETTINGS_MODULE=config.settings.dev

# Любая длинная случайная строка. Сгенерировать новую:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-long-random-string-4f9x2qewrupanno8telkzmv3

DEBUG=True

# В dev-настройках всё равно ['*'], но оставим явно
ALLOWED_HOSTS=185.129.51.40,localhost,127.0.0.1,0.0.0.0,backend

# ------------------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------------------
POSTGRES_DB=piligrim_db
POSTGRES_USER=postgres
# CHANGE_ME: придумай надёжный пароль базы (вписывай его на сервере в .env, не сюда!)
POSTGRES_PASSWORD=CHANGE_ME_db_password_123
# Внутри Docker обращаемся к базе через PgBouncer — не менять
POSTGRES_HOST=pgbouncer
POSTGRES_PORT=6432

# ------------------------------------------------------------------------------
# Redis  (db/1 — кэш Django, db/0 — Celery broker, db/2 — результаты)
# ------------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/2
# Пароль Redis оставляем пустым (сервис доступен только внутри Docker-сети)
REDIS_PASSWORD=

# ------------------------------------------------------------------------------
# Firebase (FCM push). Файл firebase-credentials.json надо залить на сервер
# рядом с docker-compose.prod.yml (он НЕ в git). Пуши сейчас не настраиваем,
# но путь оставляем, чтобы приложение не падало при инициализации.
# ------------------------------------------------------------------------------
FIREBASE_CREDENTIALS_PATH=/app/backend/firebase-credentials.json

PUSH_WEEKLY_LIMIT=3
PUSH_ALLOWED_HOUR_START=9
PUSH_ALLOWED_HOUR_END=21

# ------------------------------------------------------------------------------
# SMS-провайдер — НЕ настраиваем (OTP идёт в консоль, т.к. DEBUG=True)
# ------------------------------------------------------------------------------
SMS_PROVIDER_URL=
SMS_LOGIN=
SMS_PASSWORD=

# ------------------------------------------------------------------------------
# S3 / MinIO — хранилище медиафайлов
# ------------------------------------------------------------------------------
USE_S3=True

# Логин/пароль администратора MinIO (он же ключ доступа S3).
# CHANGE_ME: смени, минимум 8 символов у пароля.
AWS_ACCESS_KEY_ID=panno_minio_admin
AWS_SECRET_ACCESS_KEY=CHANGE_ME_minio_password_123

AWS_STORAGE_BUCKET_NAME=panno-media

# boto3 внутри Docker-сети ходит по имени сервиса minio
AWS_S3_ENDPOINT_URL=http://minio:9000

# Публичный адрес для мобильного приложения/браузера (наружу — через IP:9000)
AWS_S3_CUSTOM_DOMAIN=185.129.51.40:9000/panno-media
# http, а не https (домена и сертификата пока нет)
AWS_S3_URL_PROTOCOL=http:
# Для MinIO регион оставляем пустым
AWS_S3_REGION_NAME=
