# ==============================================
# Django
# ==============================================
# Сгенерируй: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here
DEBUG=True
# Через запятую без пробелов
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend

# ==============================================
# PostgreSQL
# ==============================================
POSTGRES_DB=panno_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-db-password
# В Docker — имя сервиса PgBouncer; локально — localhost
POSTGRES_HOST=pgbouncer
POSTGRES_PORT=6432

# ==============================================
# Redis  (db/1 — кэш Django, db/0 — Celery)
# ==============================================
REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ==============================================
# Firebase (FCM Push-уведомления)
# ==============================================
# Путь до JSON-файла с сервисным аккаунтом Firebase
# Скачай: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_CREDENTIALS_PATH=/app/backend/firebase-credentials.json

# ==============================================
# Push-уведомления: лимиты и временное окно
# ==============================================
# Макс. маркетинговых пушей в неделю на одного пользователя
PUSH_WEEKLY_LIMIT=3
# Временное окно для маркетинговых рассылок (часы, локальное время сервера)
PUSH_ALLOWED_HOUR_START=9
PUSH_ALLOWED_HOUR_END=21

# ==============================================
# SMS-провайдер (используется только при DEBUG=False)
# ==============================================
# URL API провайдера (например: https://smsc.ru/sys/send.php)
SMS_PROVIDER_URL=
SMS_LOGIN=
SMS_PASSWORD=

# ==============================================
# S3 / MinIO (медиафайлы)
# Оставь USE_S3=False для локальной разработки
# ==============================================
USE_S3=False

# Заполни только если USE_S3=True
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
# Регион (для AWS S3, например us-east-1; для MinIO можно оставить пустым)
AWS_S3_REGION_NAME=
# Только для MinIO или других S3-совместимых хранилищ (например http://minio:9000)
# Для AWS S3 оставь пустым
AWS_S3_ENDPOINT_URL=
# CDN-домен (необязательно)
AWS_S3_CUSTOM_DOMAIN=
