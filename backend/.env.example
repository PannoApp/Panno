# ==============================================
# КАК ИСПОЛЬЗОВАТЬ
# ==============================================
# 1. Скопируй файл: cp .env.example .env
# 2. Заполни обязательные поля (помечены: ОБЯЗАТЕЛЬНО)
# 3. Запусти: docker compose up --build
#
# Для локальной разработки большинство значений
# уже выставлены в рабочие дефолты — менять не нужно.

# ==============================================
# Django
# ==============================================
# Для dev можно оставить как есть.
# Для prod сгенерируй:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-debug-key-for-local-dev
DEBUG=True

# Через запятую, без пробелов.
# 10.0.2.2 — адрес хоста внутри Android-эмулятора.
# Для физического устройства добавь свой локальный IP (узнать: ipconfig getifaddr en0 / ip a).
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend,10.0.2.2

# ==============================================
# PostgreSQL
# ==============================================
POSTGRES_DB=piligrim_db
POSTGRES_USER=postgres
# ОБЯЗАТЕЛЬНО: придумай пароль
POSTGRES_PASSWORD=change-me
# В Docker — имя сервиса PgBouncer из docker-compose.yml
POSTGRES_HOST=pgbouncer
POSTGRES_PORT=6432

# ==============================================
# Redis  (db/1 — кэш Django, db/0 — Celery)
# ==============================================
# Имена сервисов из docker-compose.yml — не менять для Docker.
REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/2
# Пароль Redis — по умолчанию пустой (только для dev).
# Если задан — обнови REDIS_URL и CELERY_BROKER_URL:
#   redis://:your-password@redis:6379/1
REDIS_PASSWORD=


# ==============================================
# Firebase (FCM Push-уведомления)
# ==============================================
# Скачай JSON: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Положи файл рядом с docker-compose.yml и укажи путь внутри контейнера.
FIREBASE_CREDENTIALS_PATH=/app/backend/firebase-credentials.json

# ==============================================
# Push-уведомления: лимиты и временное окно
# ==============================================
# Макс. маркетинговых пушей в неделю на одного пользователя
PUSH_WEEKLY_LIMIT=3
# Временное окно рассылок (часы, локальное время сервера)
PUSH_ALLOWED_HOUR_START=9
PUSH_ALLOWED_HOUR_END=21

# ==============================================
# SMS-провайдер
# ==============================================
# При DEBUG=True SMS не отправляются — код выводится в лог Django.
# При DEBUG=False заполни:
SMS_PROVIDER_URL=
SMS_LOGIN=
SMS_PASSWORD=

# ==============================================
# S3 / MinIO (медиафайлы)
# ==============================================
# Для локальной разработки с MinIO: True
# Для локальной разработки без MinIO: False (файлы в media/, Django раздаёт сам — медленно)
USE_S3=False

# --- Локальный MinIO (docker-compose) ---
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_STORAGE_BUCKET_NAME=panno-media
# AWS_S3_ENDPOINT_URL=http://minio:9000         # boto3 соединение (внутри Docker-сети)
# AWS_S3_CUSTOM_DOMAIN=localhost:9000/panno-media  # публичный URL для Flutter/браузера
# AWS_S3_URL_PROTOCOL=http:                     # http для локального MinIO
# AWS_S3_REGION_NAME=                           # для MinIO оставить пустым

# --- AWS S3 (продакшн) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_ENDPOINT_URL=                          # для AWS оставить пустым
# AWS_S3_CUSTOM_DOMAIN=                         # CDN-домен (необязательно)
# AWS_S3_URL_PROTOCOL=https:

# ==============================================
# Remarked CRM (бронирования, меню, стоп-лист)
# ==============================================
# Статический токен точки и ID заведения из личного кабинета Remarked.
# См. backend/docs/remarked.md — откуда взяты и что делать при их смене.
REMARKED_API_TOKEN=5a3c459a4e05282982bcacf78a31d712
REMARKED_POINT_ID=303450
# Referer для GetToken (Reserves API v1) — должен совпадать с реальным
# исходящим IP этого сервера, иначе GetToken с point ломается с Unknown error.
# Обновить при смене сервера/деплоя (см. docs/remarked.md).
REMARKED_RESERVES_REFERER=185.98.7.12
